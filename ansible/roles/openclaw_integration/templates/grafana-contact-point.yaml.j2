# Grafana webhook Contact Point for OpenClaw
# Generated by Ansible
apiVersion: 1
contactPoints:
  - orgId: 1
    name: OpenClaw Webhook
    receivers:
      - uid: openclaw-webhook
        type: webhook
        settings:
          url: "http://openclaw:8080/webhook/grafana"
          httpMethod: POST
          autoResolve: true
          sendReminder: false
          uploadImage: true
        disableResolveMessage: false

