# OpenClaw Service Integrations
# Generated by Ansible — runtime bridge config for service-to-service communication
# This file is consumed by OpenClaw's webhook handler and tool system.

services:
  prometheus:
    url: http://prometheus:9090
    description: Prometheus metrics API
    auth: none
    endpoints:
      query: http://prometheus:9090/api/v1/query
      query_range: http://prometheus:9090/api/v1/query_range
      targets: http://prometheus:9090/api/v1/targets
      rules: http://prometheus:9090/api/v1/rules
      alerts: http://prometheus:9090/api/v1/alerts

  loki:
    url: http://loki:3100
    description: Loki logs aggregation API
    auth: none
    tenant_id: null
    endpoints:
      query_range: http://loki:3100/loki/api/v1/query_range
      labels: http://loki:3100/loki/api/v1/label
      series: http://loki:3100/loki/api/v1/series

  grafana:
    url: http://grafana:3000
    description: Grafana dashboards and alerts
    auth: none
    webhook_path: /webhook/grafana
    dashboard_url: https://{{ subdomain_grafana }}.{{ domain }}
    endpoints:
      api: http://grafana:3000/api
      health: http://grafana:3000/api/health
      alerts: http://grafana:3000/api/v1/provisioning/alert-rules

  syncthing:
    url: http://syncthing:8384
    description: Syncthing device synchronization API
    api_key: {{ syncthing_api_key | default('') }}
    endpoints:
      system: http://syncthing:8384/rest/system/status
      config: http://syncthing:8384/rest/system/config
      connections: http://syncthing:8384/rest/system/connections
      folders: http://syncthing:8384/rest/db/status
      events: http://syncthing:8384/rest/events
      metrics: http://syncthing:8384/metrics
    dashboard_url: https://{{ subdomain_syncthing }}.{{ domain }}

  vikunja:
    url: http://vikunja:3456
    description: Vikunja task management API
    api_token: {{ vikunja_api_token | default('') }}
    api_version: v1
    endpoints:
      info: http://vikunja:3456/api/v1/info
      tasks: http://vikunja:3456/api/v1/tasks
      projects: http://vikunja:3456/api/v1/projects
      labels: http://vikunja:3456/api/v1/labels
      teams: http://vikunja:3456/api/v1/teams
      users: http://vikunja:3456/api/v1/user
    dashboard_url: https://{{ subdomain_tasks }}.{{ domain }}

  navidrome:
    url: http://navidrome:4533
    description: Navidrome music streaming
    auth: none
    subsonic_compatible: true
    endpoints:
      rest: http://navidrome:4533/rest
      ping: http://navidrome:4533/ping
      health: http://navidrome:4533/healthz
    dashboard_url: https://{{ subdomain_music }}.{{ domain }}

  signal:
    url: http://signal:8080
    description: Signal Messenger REST API (signal-cli-rest-api, internal only)
    auth: none
    public_url: null
    endpoints:
      register: http://signal:8080/v1/register/{number}
      verify: http://signal:8080/v1/register/{number}/verify/{token}
      send: http://signal:8080/v2/send
      receive: http://signal:8080/v1/receive/{number}
      devices: http://signal:8080/v1/devices/{number}
      health: http://signal:8080/health
    dashboard_url: null

