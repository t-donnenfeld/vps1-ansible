#!/bin/bash
# server-config backup script
# Generated by Ansible - do not edit manually
set -euo pipefail

BACKUP_DIR="{{ backup_dir }}"
STACK_DIR="{{ stack_dir }}"
DATE=$(date +%Y%m%d_%H%M%S)
RETENTION_DAYS={{ backup_retention_days | default(30) }}
LOG_FILE="$BACKUP_DIR/backup.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"
}

log "=== Starting backup ==="

# Wait for stack to be fully ready (especially on first run)
sleep 15

# Ensure backups subdirectories exist
mkdir -p "$BACKUP_DIR/postgres"
mkdir -p "$BACKUP_DIR/volumes"
mkdir -p "$BACKUP_DIR/config"
mkdir -p "$BACKUP_DIR/vaults"

# --- 1. PostgreSQL ---
log "Dumping PostgreSQL databases..."
cd "$STACK_DIR"
# Run pg_dumpall via docker compose exec
if docker compose exec -T postgres pg_dumpall -U postgres > "$BACKUP_DIR/postgres/pg_dumpall_$DATE.sql" 2>> "$LOG_FILE"; then
    if [ -s "$BACKUP_DIR/postgres/pg_dumpall_$DATE.sql" ]; then
        gzip -f "$BACKUP_DIR/postgres/pg_dumpall_$DATE.sql"
        log "PostgreSQL dump completed: pg_dumpall_$DATE.sql.gz"
    else
        rm -f "$BACKUP_DIR/postgres/pg_dumpall_$DATE.sql"
        log "WARNING: PostgreSQL dump produced empty file (is postgres running?)"
    fi
else
    rm -f "$BACKUP_DIR/postgres/pg_dumpall_$DATE.sql"
    log "WARNING: PostgreSQL dump failed (is the stack running?)"
fi

# --- 2. Obsidian vaults ---
log "Archiving Obsidian vaults..."
VAULTS_SRC="{{ obsidian_vaults_dir }}"
if [ -d "$VAULTS_SRC" ]; then
    tar czf "$BACKUP_DIR/vaults/obsidian_vaults_$DATE.tar.gz" -C "$(dirname "$VAULTS_SRC")" "$(basename "$VAULTS_SRC")" 2>> "$LOG_FILE"
    log "Vaults archive completed: obsidian_vaults_$DATE.tar.gz"
else
    log "WARNING: Vaults directory $VAULTS_SRC does not exist, skipping"
fi

# --- 3. Docker volumes ---
log "Backing up Docker volumes..."
for vol in stack_pgdata stack_navidrome_data stack_loki_data stack_grafana_data stack_prometheus_data stack_signal_data; do
    VOL_PATH="/var/lib/docker/volumes/${vol}/_data"
    if [ -d "$VOL_PATH" ]; then
        tar czf "$BACKUP_DIR/volumes/${vol}_$DATE.tar.gz" -C "/var/lib/docker/volumes/${vol}" _data 2>> "$LOG_FILE"
        log "Volume backup completed: ${vol}_$DATE.tar.gz"
    else
        log "WARNING: Volume $VOL_PATH does not exist, skipping"
    fi
done

# --- 4. Stack config ---
log "Archiving stack config..."
if [ -d "$STACK_DIR" ]; then
    # Exclude large data dirs that are already backed up as volumes
    tar czf "$BACKUP_DIR/config/stack_config_$DATE.tar.gz" \
        --exclude='*/navidrome/data' \
        --exclude='*/loki/data' \
        --exclude='*/grafana/data' \
        --exclude='*/prometheus/data' \
        -C "$(dirname "$STACK_DIR")" "$(basename "$STACK_DIR")" 2>> "$LOG_FILE"
    log "Config archive completed: stack_config_$DATE.tar.gz"
else
    log "WARNING: Stack dir $STACK_DIR does not exist, skipping"
fi

# --- 5. Prune old backups ---
log "Pruning backups older than $RETENTION_DAYS days..."
find "$BACKUP_DIR/postgres" -name "*.sql.gz" -type f -mtime +$RETENTION_DAYS -delete 2>> "$LOG_FILE"
find "$BACKUP_DIR/volumes" -name "*.tar.gz" -type f -mtime +$RETENTION_DAYS -delete 2>> "$LOG_FILE"
find "$BACKUP_DIR/config" -name "*.tar.gz" -type f -mtime +$RETENTION_DAYS -delete 2>> "$LOG_FILE"
find "$BACKUP_DIR/vaults" -name "*.tar.gz" -type f -mtime +$RETENTION_DAYS -delete 2>> "$LOG_FILE"
log "Pruning completed."

# --- 6. Summary ---
log "=== Backup completed ==="
log "Backup size:"
du -sh "$BACKUP_DIR" >> "$LOG_FILE"

