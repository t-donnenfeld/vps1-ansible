# Generated by Ansible. Prometheus configuration.
global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: syncthing
    scrape_interval: 30s
    metrics_path: /metrics
    scheme: http
    static_configs:
      - targets:
          - syncthing:8384
        labels:
          service: syncthing
          host: {{ ansible_hostname | default(inventory_hostname) }}

  - job_name: cadvisor
    scrape_interval: 30s
    metrics_path: /metrics
    scheme: http
    static_configs:
      - targets:
          - cadvisor:8080
        labels:
          service: cadvisor
          host: {{ ansible_hostname | default(inventory_hostname) }}

  - job_name: traefik
    scrape_interval: 30s
    metrics_path: /metrics
    scheme: http
    static_configs:
      - targets:
          - traefik:8082
        labels:
          service: traefik
          host: {{ ansible_hostname | default(inventory_hostname) }}

