http:
  middlewares:
    authelia:
      forwardAuth:
        address: "http://authelia:9091/api/verify?rd=https://{{ subdomain_auth }}.{{ domain }}/"
        trustForwardHeader: true
        authResponseHeaders:
          - "Remote-User"
          - "Remote-Groups"
          - "Remote-Name"
          - "Remote-Email"
    redirect-to-https:
      redirectScheme:
        scheme: https
        permanent: true
    redirect-to-https:
      redirectScheme:
        scheme: https
        permanent: true
