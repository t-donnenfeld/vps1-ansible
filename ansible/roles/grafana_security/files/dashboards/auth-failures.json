{
  "__inputs": [],
  "__requires": [],
  "title": "Authentication Failures",
  "uid": "auth-failures",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["security", "auth", "authelia"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Total Auth Failures (24h)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"system-auth\"} |= \"Failed password\" [24h]))",
          "legendFormat": "SSH"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 200}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Traefik 401s (24h)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"traefik-access\"} | json | status_code = 401 [24h]))",
          "legendFormat": "401"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 20},
              {"color": "red", "value": 100}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Traefik 403s (24h)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"traefik-access\"} | json | status_code = 403 [24h]))",
          "legendFormat": "403"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 50}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Sudo Commands (24h)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"system-auth\"} |= \"sudo\" |= \"COMMAND\" [24h]))",
          "legendFormat": "Sudo"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 20},
              {"color": "red", "value": 100}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Auth Failures Timeline",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "sum by (host) (count_over_time({job=\"system-auth\"} |= \"Failed password\" [5m]))",
          "legendFormat": "SSH - {{ host }}"
        },
        {
          "expr": "sum(count_over_time({job=\"traefik-access\"} | json | status_code = 401 [5m]))",
          "legendFormat": "Traefik 401"
        },
        {
          "expr": "sum(count_over_time({job=\"traefik-access\"} | json | status_code = 403 [5m]))",
          "legendFormat": "Traefik 403"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["avg", "max", "sum"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 6,
      "title": "Auth Events by Source",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"system-auth\"} |= \"Failed password\" [24h]))",
          "legendFormat": "SSH Failed Password"
        },
        {
          "expr": "sum(count_over_time({job=\"system-auth\"} |= \"Invalid user\" [24h]))",
          "legendFormat": "SSH Invalid User"
        },
        {
          "expr": "sum(count_over_time({job=\"traefik-access\"} | json | status_code = 401 [24h]))",
          "legendFormat": "Traefik 401"
        },
        {
          "expr": "sum(count_over_time({job=\"traefik-access\"} | json | status_code = 403 [24h]))",
          "legendFormat": "Traefik 403"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right"},
        "pieType": "pie",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "tooltip": {"mode": "single"}
      }
    },
    {
      "id": 7,
      "title": "Recent Auth Events",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 12},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "{job=\"system-auth\"} |= `Failed` | logfmt",
          "legendFormat": ""
        }
      ],
      "options": {
        "showLabels": true,
        "showCommonLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogs": true,
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    }
  ],
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "templating": {
    "list": []
  }
}

