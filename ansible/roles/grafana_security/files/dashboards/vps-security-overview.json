{
  "__inputs": [],
  "__requires": [],
  "title": "VPS Security Overview",
  "uid": "vps-security-overview",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["security", "vps", "overview"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "id": 1,
      "title": "System Uptime",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds{job=\"node\"}",
          "format": "time_series",
          "legendFormat": "uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 86400},
              {"color": "green", "value": 604800}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "format": "time_series",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "red", "value": 85}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 3,
      "title": "Memory Usage",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes{job=\"node\"} / node_memory_MemTotal_bytes{job=\"node\"})) * 100",
          "format": "time_series",
          "legendFormat": "Memory"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 4,
      "title": "Disk Usage",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "(1 - (node_filesystem_avail_bytes{job=\"node\",fstype!=\"tmpfs\",mountpoint!=\"/boot\"} / node_filesystem_size_bytes{job=\"node\",fstype!=\"tmpfs\",mountpoint!=\"/boot\"})) * 100",
          "format": "time_series",
          "legendFormat": "Disk"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 75},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 5,
      "title": "Running Containers",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "count(container_last_seen{container_label_service!=\"\"} > 0)",
          "format": "time_series",
          "legendFormat": "Containers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "title": "SSH Auth Failures (24h)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"system-auth\"} |= \"Failed password\" [24h]))",
          "legendFormat": "Failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 200}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 7,
      "title": "CPU Usage (24h)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["avg", "max", "min"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 8,
      "title": "Memory Usage (24h)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{job=\"node\"} - node_memory_MemAvailable_bytes{job=\"node\"}",
          "legendFormat": "Used"
        },
        {
          "expr": "node_memory_MemTotal_bytes{job=\"node\"}",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["avg", "max", "min"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 9,
      "title": "Network Traffic (24h)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{job=\"node\",device!~\"veth|docker|br-|lo\"}[5m])",
          "legendFormat": "RX - {{ device }}"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{job=\"node\",device!~\"veth|docker|br-|lo\"}[5m])",
          "legendFormat": "TX - {{ device }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["avg", "max", "min"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 10,
      "title": "Disk Usage by Mount Point",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "(1 - (node_filesystem_avail_bytes{job=\"node\",fstype!=\"tmpfs\",mountpoint!=\"/boot\"} / node_filesystem_size_bytes{job=\"node\",fstype!=\"tmpfs\",mountpoint!=\"/boot\"})) * 100",
          "legendFormat": "{{ mountpoint }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 75},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      }
    },
    {
      "id": 11,
      "title": "SSH Auth Failures Timeline",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "sum by (host) (count_over_time({job=\"system-auth\"} |= \"Failed password\" [5m]))",
          "legendFormat": "{{ host }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["avg", "max", "sum"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 12,
      "title": "Service Uptime (24h)",
      "type": "table",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "avg by(job) (up[24h]) * 100",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 95},
              {"color": "green", "value": 99.9}
            ]
          },
          "custom": {
            "displayMode": "color-background"
          }
        },
        "overrides": []
      },
      "options": {
        "footer": {"show": false},
        "frameIndex": 0,
        "showHeader": true,
        "sortBy": []
      }
    }
  ],
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"value": "prometheus"}
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "datasource": {"type": "loki", "uid": "loki"},
        "enable": true,
        "name": "Wazuh Alerts",
        "query": "{job=\"wazuh-alerts\"} |= `alert`",
        "showIn": 0
      },
      {
        "datasource": {"type": "loki", "uid": "loki"},
        "enable": true,
        "name": "SSH Auth Failures",
        "query": "{job=\"system-auth\"} |= `Failed password`",
        "showIn": 0
      }
    ]
  }
}

