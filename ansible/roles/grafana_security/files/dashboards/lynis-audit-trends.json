{
  "__inputs": [],
  "__requires": [],
  "title": "Lynis Audit Trends",
  "uid": "lynis-audit-trends",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["security", "lynis", "compliance"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Current Hardening Score",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "topk(1, sum by (hardening_index) (count_over_time({job=\"lynis-audit\"} [1h])))",
          "legendFormat": "Score"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 100,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "green", "value": 80}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Warnings (Last Audit)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 6, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "topk(1, sum by (warnings_count) (count_over_time({job=\"lynis-audit\"} [1h])))",
          "legendFormat": "Warnings"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 30}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Suggestions (Last Audit)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 10, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "topk(1, sum by (suggestions_count) (count_over_time({job=\"lynis-audit\"} [1h])))",
          "legendFormat": "Suggestions"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 20},
              {"color": "red", "value": 50}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Tests Performed (Last Audit)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 14, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "topk(1, sum by (tests_count) (count_over_time({job=\"lynis-audit\"} [1h])))",
          "legendFormat": "Tests"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 200}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Last Audit Time",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "topk(1, max by (host) (count_over_time({job=\"lynis-audit\"} [1h])))",
          "legendFormat": "Last"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "green", "value": 1}
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "title": "Hardening Score Trend (30 days)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "avg by (host) (count_over_time({job=\"lynis-audit\"} | json [1d]))",
          "legendFormat": "Score"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 100,
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["avg", "max", "min"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"},
        "lineWidth": 2,
        "fillOpacity": 20,
        "pointSize": 5
      }
    },
    {
      "id": 7,
      "title": "Warning & Suggestion Counts Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "avg by (host) (count_over_time({job=\"lynis-audit\"} | json [1d]))",
          "legendFormat": "Warnings"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {
        "legend": {"calcs": ["avg", "max", "min"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 8,
      "title": "Recent Lynis Audit Logs",
      "type": "logs",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "{job=\"lynis-audit\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "showLabels": true,
        "showCommonLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogs": true,
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    }
  ],
  "refresh": "1h",
  "time": {"from": "now-30d", "to": "now"},
  "timepicker": {},
  "templating": {
    "list": []
  }
}

